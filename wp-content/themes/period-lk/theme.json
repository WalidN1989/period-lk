{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary",       "color": "#C2185B", "name": "Primary" },
        { "slug": "primary-dark",  "color": "#880E4F", "name": "Primary Dark" },
        { "slug": "primary-light", "color": "#F48FB1", "name": "Primary Light" },
        { "slug": "surface",       "color": "#FFF5F7", "name": "Surface" },
        { "slug": "text",          "color": "#1A1A2E", "name": "Text" },
        { "slug": "text-muted",    "color": "#5C5C72", "name": "Text Muted" },
        { "slug": "white",         "color": "#FFFFFF", "name": "White" }
      ]
    },
    "typography": {
      "fontSizes": [
        { "slug": "small",  "size": "0.875rem", "name": "Small"  },
        { "slug": "normal", "size": "1rem",     "name": "Normal" },
        { "slug": "large",  "size": "1.25rem",  "name": "Large"  },
        { "slug": "x-large","size": "1.5rem",   "name": "X-Large"}
      ],
      "customFontSize": false,
      "dropCap": false
    },
    "spacing": {
      "units": ["px", "rem", "%", "vw"]
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "color": {
      "background": "#FFFFFF",
      "text": "#1A1A2E"
    },
    "typography": {
      "fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
      "fontSize": "1rem",
      "lineHeight": "1.65"
    }
  }
}
