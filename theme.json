{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        { "name": "Wine",          "slug": "wine",          "color": "#6a1b2a" },
        { "name": "Wine deep",     "slug": "wine-deep",     "color": "#45101b" },
        { "name": "Blush",         "slug": "blush",         "color": "#f7e6ea" },
        { "name": "Cream",         "slug": "cream",         "color": "#fbf2ea" },
        { "name": "Canvas",        "slug": "canvas",        "color": "#fffdfb" },
        { "name": "Ink",           "slug": "ink",           "color": "#2a1216" },
        { "name": "Body",          "slug": "body",          "color": "#5c474c" },
        { "name": "Muted",         "slug": "muted",         "color": "#8c757a" },
        { "name": "Gold",          "slug": "gold",          "color": "#c08a3e" },
        { "name": "Sale red",      "slug": "sale",          "color": "#b3253a" },
        { "name": "On primary",    "slug": "on-primary",    "color": "#fff7f3" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Playfair Display",
          "slug": "serif",
          "fontFamily": "\"Playfair Display\", \"Hoefler Text\", Georgia, serif"
        },
        {
          "name": "Hanken Grotesk",
          "slug": "sans",
          "fontFamily": "\"Hanken Grotesk\", -apple-system, system-ui, \"Segoe UI\", Roboto, sans-serif"
        }
      ]
    },
    "layout": {
      "contentSize": "920px",
      "wideSize": "1200px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw"]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "#fffdfb",
      "text": "#5c474c"
    },
    "typography": {
      "fontFamily": "var(--font-sans)",
      "fontSize": "16px",
      "lineHeight": "1.55"
    },
    "elements": {
      "h1": { "typography": { "fontFamily": "var(--font-serif)", "fontWeight": "600", "color": "#2a1216" } },
      "h2": { "typography": { "fontFamily": "var(--font-serif)", "fontWeight": "600", "color": "#2a1216" } },
      "h3": { "typography": { "fontFamily": "var(--font-serif)", "fontWeight": "600", "color": "#2a1216" } },
      "link": { "color": { "text": "#6a1b2a" } }
    }
  }
}
